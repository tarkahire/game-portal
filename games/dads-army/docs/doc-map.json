{
  "_comment": "Maps code paths to documentation files. Used by doc-audit.sh and Claude Code.",
  "version": 1,
  "path_rules": [
    {"pattern": "src/api/queries.js", "docs": ["architecture.md", "setup.md"], "notes": "Query layer — affects data flow and setup instructions"},
    {"pattern": "src/api/subscriptions.js", "docs": ["architecture.md"], "notes": "Realtime subscriptions — affects architecture"},
    {"pattern": "src/api/supabaseClient.js", "docs": ["architecture.md", "setup.md"], "notes": "Client config — affects setup instructions"},
    {"pattern": "src/main.js", "docs": ["architecture.md"], "notes": "Bootstrap/scene flow — affects frontend architecture"},
    {"pattern": "src/systems/AuthManager.js", "docs": ["architecture.md", "setup.md"], "notes": "Auth changes — affects security model and setup"},
    {"pattern": "src/systems/SceneManager.js", "docs": ["architecture.md"], "notes": "Scene lifecycle — affects frontend architecture"},
    {"pattern": "src/systems/ResourceCalculator.js", "docs": ["resources.md"], "notes": "Resource math — affects resource system docs"},
    {"pattern": "src/systems/CombatPredictor.js", "docs": ["combat.md"], "notes": "Combat math — affects combat system docs"},
    {"pattern": "src/systems/SupplyChainCalculator.js", "docs": ["supply-lines.md"], "notes": "Supply logic — affects supply chain docs"},
    {"pattern": "src/systems/DepletionTracker.js", "docs": ["resources.md", "server-lifecycle.md"], "notes": "Depletion — affects resources and server lifecycle"},
    {"pattern": "src/config/resourceDefs.js", "docs": ["resources.md"], "notes": "Resource definitions"},
    {"pattern": "src/config/buildingDefs.js", "docs": ["cities.md"], "notes": "Building definitions"},
    {"pattern": "src/config/unitDefs.js", "docs": ["military.md"], "notes": "Unit definitions"},
    {"pattern": "src/config/researchDefs.js", "docs": ["research-tree.md"], "notes": "Research definitions"},
    {"pattern": "src/config/alignmentDefs.js", "docs": ["alignments.md"], "notes": "Alignment definitions"},
    {"pattern": "src/config/gameConfig.js", "docs": ["server-lifecycle.md", "resources.md"], "notes": "Game balance constants"},
    {"pattern": "src/scenes/WorldMapScene.js", "docs": ["map.md", "architecture.md"], "notes": "Map scene"},
    {"pattern": "src/scenes/CityScene.js", "docs": ["cities.md", "architecture.md"], "notes": "City management scene"},
    {"pattern": "src/scenes/ArmyScene.js", "docs": ["military.md", "architecture.md"], "notes": "Army scene"},
    {"pattern": "src/scenes/ResearchScene.js", "docs": ["research-tree.md", "architecture.md"], "notes": "Research scene"},
    {"pattern": "src/scenes/DiplomacyScene.js", "docs": ["diplomacy.md", "architecture.md"], "notes": "Diplomacy scene"},
    {"pattern": "src/scenes/IntelligenceScene.js", "docs": ["intelligence.md", "architecture.md"], "notes": "Intel scene"},
    {"pattern": "src/scenes/FieldScene.js", "docs": ["resources.md", "architecture.md"], "notes": "Resource field scene"},
    {"pattern": "src/scenes/BattleReportScene.js", "docs": ["combat.md", "architecture.md"], "notes": "Battle report scene"},
    {"pattern": "src/map/*", "docs": ["map.md", "architecture.md"], "notes": "Hex renderer, camera, fog of war"},
    {"pattern": "src/ui/*", "docs": ["architecture.md"], "notes": "UI panel changes"},
    {"pattern": "sql/*_core_tables*", "docs": ["architecture.md"], "notes": "Core schema changes"},
    {"pattern": "sql/*_map_tables*", "docs": ["architecture.md", "map.md"], "notes": "Map schema changes"},
    {"pattern": "sql/*_city_tables*", "docs": ["architecture.md", "cities.md"], "notes": "City schema changes"},
    {"pattern": "sql/*_military_tables*", "docs": ["architecture.md", "military.md", "combat.md"], "notes": "Military schema changes"},
    {"pattern": "sql/*_research_tables*", "docs": ["architecture.md", "research-tree.md"], "notes": "Research schema changes"},
    {"pattern": "sql/*_economy_tables*", "docs": ["architecture.md", "economy.md"], "notes": "Economy schema changes"},
    {"pattern": "sql/*_rls*", "docs": ["architecture.md"], "notes": "RLS policy changes — security model"},
    {"pattern": "sql/*_functions*", "docs": ["architecture.md"], "notes": "RPC/tick function changes"},
    {"pattern": "sql/*_cron*", "docs": ["architecture.md", "server-lifecycle.md"], "notes": "Cron job changes"},
    {"pattern": "sql/seed_*", "docs": ["setup.md"], "notes": "Seed data changes — setup instructions"},
    {"pattern": "index.html", "docs": ["architecture.md"], "notes": "Entry point changes"},
    {"pattern": "style.css", "docs": [], "notes": "CSS-only — rarely needs doc updates unless new UI patterns"},
    {"pattern": "CLAUDE.md", "docs": [], "notes": "Self-referencing — no other docs need updating"}
  ],
  "commit_patterns": [
    {"regex": "fix|bug|broken|error|wrong|mismatch|missing|does not exist", "docs": ["bug.md"], "action": "Add or update BUG-XXX entry"},
    {"regex": "add|implement|create|new feature|introduce", "docs": ["todo.md"], "action": "Mark todo item as done or add if unplanned"},
    {"regex": "refactor|rename|restructure|move", "docs": ["architecture.md"], "action": "Update architecture if structural change"},
    {"regex": "schema|ALTER|CREATE TABLE|DROP", "docs": ["architecture.md", "setup.md"], "action": "Update schema docs and setup instructions"}
  ],
  "always_update": {
    "end_of_session": ["development-log.md"],
    "note": "Add dated entry: what changed, decisions, bugs, lessons learned"
  }
}
